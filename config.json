{
  "steps": [
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "bodyType": "urlencoded",
      "body": {
        "grant_type": "password",
        "client_secret": "b86e30a8-ae29-467a-a71f-65c73f2ff5e3",
        "client_id": "cash-app"
      },
      "injectHeaders": {
        "User-Agent": "Dalvik/2.1.0",
        "Accept": "application/json, text/plain, */*",
        "silentLogin": "true",
        "firstTimeLogin": "true",
        "x-agent-operatingsystem": "13",
        "clientId": "AnaVodafoneAndroid",
        "x-agent-device": "OPPO CPH2235",
        "x-agent-version": "2024.7.2.1",
        "x-agent-build": "1050",
        "digitalId": "24S0M31T0I9RK"
      },
      "extractKey": "access_token",
      "errorKey": "error_description"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "bodyType": "json",
      "bodyTemplate": {
        "channel": {
          "name": "MobileApp"
        },
        "orderItem": [
          {
            "action": "insert",
            "id": "{productId}",
            "product": {
              "characteristic": [
                {
                  "name": "PaymentMethod",
                  "value": "VFCash"
                },
                {
                  "name": "USE_EMONEY",
                  "value": "False"
                },
                {
                  "name": "MerchantCode",
                  "value": "81841829"
                }
              ],
              "id": "{productId}",
              "relatedParty": [
                {
                  "id": "{sender}",
                  "name": "MSISDN",
                  "role": "Subscriber"
                },
                {
                  "id": "{receiver}",
                  "name": "Receiver",
                  "role": "Receiver"
                }
              ]
            },
            "@type": "{productId}",
            "eCode": 0
          }
        ],
        "relatedParty": [
          {
            "id": "{pin}",
            "name": "pin",
            "role": "Requestor"
          }
        ],
        "@type": "CashFakkaAndMared"
      },
      "injectHeaders": {
        "Accept": "application/json",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "Bearer {access_token}"
      },
      "successCondition": "state == 'Completed' || complete == true",
      "errorKey": "reason"
    }
  ]
}
