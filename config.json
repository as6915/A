{
  "verbose": true,
  "logRequest": true,
  "logResponse": true,
  "steps": [
    {
      "method": "GET",
      "url": "http://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth?client_id=ana-vodafone-app-seamless",
      "headers": {
        "User-Agent": "okhttp/4.11.0",
        "Connection": "Keep-Alive",
        "Accept-Encoding": "gzip",
        "x-agent-operatingsystem": "13",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "ar",
        "x-agent-device": "NativeApp",
        "x-agent-version": "2024.7.2.1",
        "x-agent-build": "1050",
        "digitalId": "DynamicApp"
      },
      "extract": {
        "from": "json",
        "key": "seamlessToken",
        "deepSearch": true
      },
      "saveAs": "seamlessToken",
      "error": "فشل تسجيل الدخول"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "headers": {
        "User-Agent": "okhttp/4.11.0",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip",
        "silentLogin": "true",
        "seamlessToken": "{seamlessToken}",
        "firstTimeLogin": "true",
        "x-agent-operatingsystem": "13",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "ar",
        "x-agent-device": "NativeApp",
        "x-agent-version": "2024.7.2.1",
        "x-agent-build": "1050",
        "digitalId": "DynamicApp",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "bodyType": "urlencoded",
      "body": "grant_type=password&client_secret=b86e30a8-ae29-467a-a71f-65c73f2ff5e3&client_id=cash-app",
      "extract": [
        {
          "from": "json",
          "key": "access_token",
          "deepSearch": true,
          "saveAs": "access_token"
        },
        {
          "from": "json",
          "key": "token_type",
          "deepSearch": true,
          "saveAs": "token_type"
        }
      ],
      "error": "فشل الحصول على التوكن",
      "logFullResponse": true
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "headers": {
        "User-Agent": "okhttp/4.11.0",
        "Connection": "Keep-Alive",
        "Accept": "application/json",
        "Accept-Encoding": "gzip",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "{token_type} {access_token}",
        "x-agent-operatingsystem": "13",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "ar",
        "x-agent-device": "NativeApp",
        "x-agent-version": "2024.7.2.1",
        "x-agent-build": "1050",
        "digitalId": "DynamicApp"
      },
      "bodyTemplate": "{\"channel\":{\"name\":\"MobileApp\"},\"orderItem\":[{\"action\":\"insert\",\"id\":\"PRODUCT_ID\",\"product\":{\"characteristic\":[{\"name\":\"PaymentMethod\",\"value\":\"VFCash\"},{\"name\":\"USE_EMONEY\",\"value\":\"False\"},{\"name\":\"MerchantCode\",\"value\":\"81841829\"}],\"id\":\"PRODUCT_ID\",\"relatedParty\":[{\"id\":\"SENDER_WITHOUT_ZERO\",\"name\":\"MSISDN\",\"role\":\"Subscriber\"},{\"id\":\"RECEIVER\",\"name\":\"Receiver\",\"role\":\"Receiver\"}]},\"@type\":\"PRODUCT_ID\",\"eCode\":0}],\"relatedParty\":[{\"id\":\"PIN\",\"name\":\"pin\",\"role\":\"Requestor\"}],\"@type\":\"CashFakkaAndMared\"}",
      "placeholders": {
        "PRODUCT_ID": "{productId}",
        "SENDER_WITHOUT_ZERO": "{sender_no_zero}",
        "RECEIVER": "{receiver}",
        "PIN": "{pin}"
      },
      "extract": {
        "from": "json",
        "key": "state",
        "deepSearch": true
      },
      "saveAs": "orderState",
      "error": "reason",
      "successCondition": "state == 'Completed' || complete == true",
      "logFullRequest": true,
      "logFullResponse": true
    }
  ]
}
