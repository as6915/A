{
  "steps": [
    {
      "method": "GET",
      "url": "http://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth?client_id=ana-vodafone-app-seamless",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Connection": "keep-alive"
      },
      "extract": {
        "from": "json",
        "key": "seamlessToken",
        "deepSearch": true
      },
      "saveAs": "seamlessToken",
      "error": "فشل تسجيل الدخول",
      "httpSuccess": [200, 302]
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Connection": "keep-alive",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "bodyType": "urlencoded",
      "body": "grant_type=password&client_secret=b86e30a8-ae29-467a-a71f-65c73f2ff5e3&client_id=cash-app",
      "extract": {
        "from": "json",
        "key": "access_token",
        "deepSearch": true
      },
      "saveAs": "access_token",
      "error": "فشل الحصول على التوكن",
      "httpSuccess": [200]
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Connection": "keep-alive",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "Bearer {access_token}"
      },
      "body": {
        "channel": {"name": "MobileApp"},
        "orderItem": [
          {
            "action": "insert",
            "id": "{productId}",
            "product": {
              "characteristic": [
                {"name": "PaymentMethod", "value": "VFCash"},
                {"name": "USE_EMONEY", "value": "False"},
                {"name": "MerchantCode", "value": "81841829"}
              ],
              "id": "{productId}",
              "relatedParty": [
                {"id": "{sender_no_zero}", "name": "MSISDN", "role": "Subscriber"},
                {"id": "{receiver}", "name": "Receiver", "role": "Receiver"}
              ]
            },
            "@type": "{productId}",
            "eCode": 0
          }
        ],
        "relatedParty": [
          {"id": "{pin}", "name": "pin", "role": "Requestor"}
        ],
        "@type": "CashFakkaAndMared"
      },
      "extract": [
        {
          "from": "json",
          "key": "state",
          "deepSearch": true,
          "saveAs": "orderState"
        },
        {
          "from": "json",
          "key": "orderId",
          "deepSearch": true,
          "saveAs": "orderId",
          "required": true
        }
      ],
      "error": "reason",
      "httpSuccess": [200],
      "successCondition": "(state == 'Completed' || complete == true) && orderId != null && orderId != '' && orderId != 'null'"
    }
  ]
}
