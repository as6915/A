    ],
    "os_versions": ["16", "15", "14", "13"],
    "app_versions": ["2025.11.1", "2025.10.1", "2025.09.1"],
    "app_builds": ["1063", "1062", "1061"],
    "device_ids": []
  },
  "permissions": {
    "roles": {
      "Admin": {
        "level": 0,
        "permissions": ["all"]
      },
      "Moderator": {
        "level": 1,
        "permissions": ["view_users", "edit_points"]
      },
      "VIP": {
        "level": 2,
        "permissions": ["priority_support", "bonus_points"]
      },
      "User": {
        "level": 3,
        "permissions": ["recharge", "view_history"]
      }
    }
  },
  "features": {
    "autoLogin": true,
    "offlineSupport": true,
    "languages": ["ar", "en"],
    "defaultLanguage": "ar",
    "randomizeHeaders": true,
    "sslPinning": true,
    "enableWallet": true,
    "enableHistory": true,
    "enableNotifications": true,
    "enableSearch": true,
    "enableProfile": true,
