{
  "steps": [
    {
      "method": "GET",
      "url": "https://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth?client_id=ana-vodafone-app-seamless",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
        "Accept-Language": "ar,en;q=0.9",
        "Accept-Encoding": "gzip, deflate, br",
        "Connection": "keep-alive",
        "Upgrade-Insecure-Requests": "1"
      },
      "extract": {
        "from": "header",
        "key": "Location"
      },
      "saveAs": "seamlessToken",
      "error": "فشل تسجيل الدخول"
    },
    {
      "method": "GET",
      "url": "https://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth?client_id=ana-vodafone-app-seamless",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
        "Accept-Language": "ar,en;q=0.9",
        "Accept-Encoding": "gzip, deflate, br",
        "Connection": "keep-alive",
        "Upgrade-Insecure-Requests": "1"
      },
      "extract": {
        "from": "header",
        "key": "Location"
      },
      "saveAs": "authCode",
      "error": "فشل الحصول على الكود"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "bodyType": "urlencoded",
      "body": "grant_type=authorization_code&client_secret=b86e30a8-ae29-467a-a71f-65c73f2ff5e3&client_id=cash-app&code={authCode}",
      "extract": {
        "from": "json",
        "key": "access_token"
      },
      "saveAs": "access_token",
      "error": "فشل الحصول على التوكن"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "bodyType": "urlencoded",
      "body": "grant_type=password&client_secret=b86e30a8-ae29-467a-a71f-65c73f2ff5e3&client_id=cash-app",
      "extract": {
        "from": "json",
        "key": "access_token"
      },
      "saveAs": "access_token_fallback",
      "error": "فشل الحصول على التوكن",
      "optional": true
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "application/json",
        "Accept-Encoding": "gzip, deflate, br",
        "Accept-Language": "ar,en;q=0.9",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "Bearer {access_token}"
      },
      "body": {
        "channel": {"name": "MobileApp"},
        "orderItem": [
          {
            "action": "insert",
            "id": "{productId}",
            "product": {
              "characteristic": [
                {"name": "PaymentMethod", "value": "VFCash"},
                {"name": "USE_EMONEY", "value": "False"},
                {"name": "MerchantCode", "value": "81841829"}
              ],
              "id": "{productId}",
              "relatedParty": [
                {"id": "{sender_no_zero}", "name": "MSISDN", "role": "Subscriber"},
                {"id": "{receiver}", "name": "Receiver", "role": "Receiver"}
              ]
            },
            "@type": "{productId}",
            "eCode": 0
          }
        ],
        "relatedParty": [
          {"id": "{pin}", "name": "pin", "role": "Requestor"}
        ],
        "@type": "CashFakkaAndMared"
      },
      "extract": {
        "from": "json",
        "key": "state"
      },
      "saveAs": "orderState",
      "error": "reason",
      "successCondition": "state == 'Completed' || complete == true"
    }
  ]
}
