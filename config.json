  "services": [
    {
      "id": "vodafone_recharge",
      "name": "شحن فودافون",
      "description": "شحن رصيد فودافون بكروت الفكة وباقات المارد",
      "categoryId": "fakka",
      "icon": "phone_android",
      "method": "POST",
      "endpoint": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "headers": {
        "Content-Type": "application/json; charset=UTF-8",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip",
        "Accept-Language": "ar",
        "Connection": "Keep-Alive",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "clientId": "AnaVodafoneAndroid"
      },
      "auth_required": true,
      "requires_token": true,
      "parameters": [
        {
          "name": "product_id",
          "type": "select",
          "required": true,
          "label": "نوع الشحن",
          "options": [
            {"value": "Fakka_2.5_Unite", "label": "فكة 2.5 جنيه"},
            {"value": "Fakka_4.25_Unite", "label": "فكة 4.25 جنيه"},
            {"value": "Fakka_5_Unite", "label": "فكة 5 جنيه"},
            {"value": "Fakka_6_NewUnite", "label": "فكة 6 جنيه (جديد)"},
            {"value": "Fakka_7_Unite", "label": "فكة 7 جنيه"},
            {"value": "Fakka_9_Unite", "label": "فكة 9 جنيه"},
            {"value": "Fakka_10_Unite", "label": "فكة 10 جنيه"},
            {"value": "Fakka_10_NewUnite", "label": "فكة 10 جنيه (جديد)"},
            {"value": "Fakka_10.5_Unite", "label": "فكة 10.5 جنيه"},
            {"value": "Fakka_11.5_Unite", "label": "فكة 11.5 جنيه"},
            {"value": "Fakka_12_Unite", "label": "فكة 12 جنيه"},
            {"value": "Fakka_12.5_Unite", "label": "فكة 12.5 جنيه"},
            {"value": "Fakka_13_Unite", "label": "فكة 13 جنيه"},
            {"value": "Fakka_13.5_Unite", "label": "فكة 13.5 جنيه"},
            {"value": "Fakka_15_Unite", "label": "فكة 15 جنيه"},
            {"value": "Fakka_15_NewUnite", "label": "فكة 15 جنيه (جديد)"},
            {"value": "Fakka_15.5_Unite", "label": "فكة 15.5 جنيه"},
            {"value": "Fakka_16.5_Unite", "label": "فكة 16.5 جنيه"},
            {"value": "Fakka_17.5_Unite", "label": "فكة 17.5 جنيه"},
            {"value": "Fakka_19.5_NewUnite", "label": "فكة 19.5 جنيه (جديد)"},
            {"value": "Fakka_20_Unite", "label": "فكة 20 جنيه"},
            {"value": "Fakka_26_Unite", "label": "فكة 26 جنيه"},
            {"value": "Mared_10_Minuts", "label": "مارد 10 دقائق"},
            {"value": "Mared_10_Flexs", "label": "مارد 10 فليكس"},
            {"value": "Mared_10_Social", "label": "مارد 10 سوشيال"}
          ]
        },
        {
          "name": "receiver",
          "type": "string",
          "required": true,
          "label": "رقم المستفيد",
          "placeholder": "01xxxxxxxxx",
          "validation": "^(01)[0-9]{9}$",
          "error_message": "رقم الهاتف غير صحيح"
        },
        {
          "name": "pin",
          "type": "string",
          "required": true,
          "label": "كود فودافون كاش",
          "placeholder": "******",
          "validation": "^[0-9]{6}$",
          "error_message": "الكود يجب أن يكون 6 أرقام",
          "inputType": "password"
        }
      ],
      "request_body": {
        "channel": {"name": "MobileApp"},
        "orderItem": [
          {
            "action": "insert",
            "id": "{product_id}",
            "product": {
              "characteristic": [
                {"name": "PaymentMethod", "value": "VFCash"},
                {"name": "USE_EMONEY", "value": "False"},
                {"name": "MerchantCode", "value": "{merchant_code}"}
              ],
              "id": "{product_id}",
              "relatedParty": [
                {"id": "{msisdn}", "name": "MSISDN", "role": "Subscriber"},
                {"id": "{receiver}", "name": "Receiver", "role": "Receiver"}
              ]
            },
            "@type": "{product_id}",
            "eCode": 0
          }
        ],
        "relatedParty": [{"id": "{pin}", "name": "pin", "role": "Requestor"}],
        "@type": "CashFakkaAndMared"
      },
      "responseMapping": {
        "success": "$.state == 'Completed'",
        "state": "$.state",
        "message": "$.message",
        "orderId": "$.orderId"
      },
      "pointsCost": 1,
      "requires_auth": true
    }
  ],
