  "auth_flow": {
    "step1": {
      "url": "http://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth",
      "method": "GET",
      "params": {"client_id": "cash-app"},
      "headers": {
        "x-agent-operatingsystem": "{os_version}",
        "clientId": "AnaVodafoneAndroid",
        "x-agent-device": "{device_name}",
        "x-agent-version": "{app_version}",
        "x-agent-build": "{app_build}",
        "digitalId": "",
        "device-id": "{device_id}"
      },
      "response": {
        "seamlessToken": "$.seamlessToken",
        "msisdn": "$.msisdn"
      }
    },
    "step2": {
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "method": "POST",
      "body_type": "form",
      "body": {
        "grant_type": "password",
        "client_secret": "{client_secret}",
        "client_id": "cash-app"
      },
      "headers": {
        "silentLogin": "true",
        "CRP": "false",
        "seamlessToken": "{seamless_token}",
        "firstTimeLogin": "true",
        "x-agent-operatingsystem": "{os_version}",
        "clientId": "AnaVodafoneAndroid",
        "x-agent-device": "{device_name}",
        "x-agent-version": "{app_version}",
        "x-agent-build": "{app_build}",
        "digitalId": "",
        "device-id": "{device_id}",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "response": {
        "accessToken": "$.access_token",
        "expiresIn": "$.expires_in",
        "tokenType": "$.token_type"
      }
    }
  },
