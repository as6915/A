    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "bodyType": "json",
      "bodyTemplate": {
        "channel": {"name": "MobileApp"},
        "orderItem": [{
          "action": "insert",
          "id": "{productId}",
          "product": {
            "characteristic": [
              {"name": "PaymentMethod", "value": "VFCash"},
              {"name": "USE_EMONEY", "value": "False"},
              {"name": "MerchantCode", "value": "81841829"}
            ],
            "id": "{productId}",
            "relatedParty": [
              {"id": "{sender_raw}", "name": "MSISDN", "role": "Subscriber"},
              {"id": "{receiver}", "name": "Receiver", "role": "Receiver"}
            ]
          },
          "@type": "{productId}",
          "eCode": 0
        }],
        "relatedParty": [
          {"id": "{pin}", "name": "pin", "role": "Requestor"}
        ],
        "@type": "CashFakkaAndMared"
      },
      "injectHeaders": {
        "Accept": "application/json",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "Bearer {access_token}"
      },
      "successCondition": "state == 'Completed' || complete == true",
      "errorKey": "reason"
    }
