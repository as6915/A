{
  "steps": [
    {
      "method": "GET",
      "url": "https://mobile.vodafone.com.eg/checkSeamless/realms/vf-realm/protocol/openid-connect/auth?client_id=ana-vodafone-app-seamless",
      "headers": {
        "User-Agent": "{device_user_agent}",
        "Connection": "Keep-Alive",
        "Accept-Encoding": "gzip",
        "x-agent-operatingsystem": "{os_version}",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "{device_language}",
        "x-agent-device": "{device_model}",
        "x-agent-version": "{app_version}",
        "x-agent-build": "{app_build}",
        "digitalId": "{device_digital_id}"
      },
      "extract": {
        "from": "json",
        "key": "seamlessToken"
      },
      "saveAs": "seamlessToken",
      "error": "فشل تسجيل الدخول"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/auth/realms/vf-realm/protocol/openid-connect/token",
      "headers": {
        "User-Agent": "{device_user_agent}",
        "Accept": "application/json, text/plain, */*",
        "Accept-Encoding": "gzip",
        "silentLogin": "true",
        "seamlessToken": "{seamlessToken}",
        "firstTimeLogin": "true",
        "x-agent-operatingsystem": "{os_version}",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "{device_language}",
        "x-agent-device": "{device_model}",
        "x-agent-version": "{app_version}",
        "x-agent-build": "{app_build}",
        "digitalId": "{device_digital_id}",
        "Content-Type": "application/x-www-form-urlencoded"
      },
      "bodyType": "urlencoded",
      "body": {
        "grant_type": "password",
        "client_secret": "b86e30a8-ae29-467a-a71f-65c73f2ff5e3",
        "client_id": "cash-app"
      },
      "extract": {
        "from": "json",
        "key": "access_token"
      },
      "saveAs": "access_token",
      "error": "فشل الحصول على التوكن"
    },
    {
      "method": "POST",
      "url": "https://mobile.vodafone.com.eg/services/dxl/pom/productOrder",
      "headers": {
        "User-Agent": "{device_user_agent}",
        "Connection": "Keep-Alive",
        "Accept": "application/json",
        "Accept-Encoding": "gzip",
        "Content-Type": "application/json",
        "api-host": "ProductOrderingManagement",
        "useCase": "CashFakkaAndMared",
        "api-version": "v2",
        "msisdn": "{sender}",
        "Authorization": "Bearer {access_token}",
        "x-agent-operatingsystem": "{os_version}",
        "clientId": "AnaVodafoneAndroid",
        "Accept-Language": "{device_language}",
        "x-agent-device": "{device_model}",
        "x-agent-version": "{app_version}",
        "x-agent-build": "{app_build}",
        "digitalId": "{device_digital_id}"
      },
      "body": {
        "channel": {"name": "MobileApp"},
        "orderItem": [
          {
            "action": "insert",
            "id": "{productId}",
            "product": {
              "characteristic": [
                {"name": "PaymentMethod", "value": "VFCash"},
                {"name": "USE_EMONEY", "value": "False"},
                {"name": "MerchantCode", "value": "81841829"}
              ],
              "id": "{productId}",
              "relatedParty": [
                {"id": "{sender_no_zero}", "name": "MSISDN", "role": "Subscriber"},
                {"id": "{receiver}", "name": "Receiver", "role": "Receiver"}
              ]
            },
            "@type": "{productId}",
            "eCode": 0
          }
        ],
        "relatedParty": [
          {"id": "{pin}", "name": "pin", "role": "Requestor"}
        ],
        "@type": "CashFakkaAndMared"
      },
      "extract": {
        "from": "json",
        "key": "state"
      },
      "saveAs": "orderState",
      "error": "reason",
      "successCondition": "state == 'Completed' || complete == true"
    }
  ]
}
